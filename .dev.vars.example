# Copy this file to `.dev.vars` for local development with `wrangler pages dev`.
# `.dev.vars` is git-ignored — never commit real secrets.

# Telegram bot token from @BotFather
BOT_TOKEN=123456789:AA...your-bot-token...

# Target Telegram group/chat id (get it from @userinfobot or getUpdates).
# Group ids are usually negative, e.g. -1001234567890
CHAT_ID=-1001234567890

# Optional: shared secret Telegram sends back on each webhook call.
# Set the same value with setWebhook (?secret_token=...) to reject spoofed calls.
WEBHOOK_SECRET=some-long-random-string
